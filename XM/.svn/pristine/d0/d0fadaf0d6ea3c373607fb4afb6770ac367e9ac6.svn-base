  exhibits:
  - id: 1
    name: "\u9752\u94DC\u9F0E"
    description: "\u5546\u4EE3\u9752\u94DC\u5668\uFF0C\u4E09\u8DB3\u4E24\u8033\uFF0C\u8179\u90E8\u9970\u9955\u992E\u7EB9\uFF0C\u901A\u9AD8\u7EA6120\u5398\u7C73\u3002\u4E3A\u5546\u738B\u5BA4\u796D\u7940\u793C\u5668\uFF0C\u4F53\u73B0\u4E86\u5546\u4EE3\u9752\u94DC\u94F8\u9020\u5DE5\u827A\u7684\u5DC5\u5CF0\u6C34\u5E73\u3002"
    theme: 0
  - id: 2
    name: "\u7389\u74A7"
    description: "\u65B0\u77F3\u5668\u65F6\u4EE3\u826F\u6E1A\u6587\u5316\u7389\u5668\uFF0C\u5706\u5F62\u6241\u5E73\uFF0C\u4E2D\u592E\u6709\u5B54\u3002\u76F4\u5F84\u7EA620\u5398\u7C73\uFF0C\u7389\u8D28\u6E29\u6DA6\uFF0C\u8868\u9762\u629B\u5149\u7CBE\u7EC6\u3002\u53E4\u4EBA\u4EE5\u74A7\u796D\u5929\uFF0C\u662F\u793C\u5236\u6587\u5316\u7684\u91CD\u8981\u8F7D\u4F53\u3002"
    theme: 0
  - id: 3
    name: "\u6050\u9F99\u5316\u77F3"
    description: "\u4F8F\u7F57\u7EAA\u65F6\u671F\u9738\u738B\u9F99\u9AA8\u9ABC\u5316\u77F3\uFF0C\u53D1\u6398\u4E8E\u5317\u7F8E\u5730\u533A\u3002\u5316\u77F3\u4FDD\u5B58\u5B8C\u597D\uFF0C\u5305\u542B\u5934\u9AA8\u3001\u810A\u690E\u53CA\u56DB\u80A2\u9AA8\u9ABC\uFF0C\u8EAB\u957F\u7EA612\u7C73\uFF0C\u5C55\u73B0\u4E86\u4E2D\u751F\u4EE3\u9876\u7EA7\u63A0\u98DF\u8005\u7684\u96C4\u59FF\u3002"
    theme: 1
  - id: 4
    name: "\u6708\u5CA9\u6837\u672C"
    description: "\u963F\u6CE2\u7F5717\u53F7\u4EFB\u52A1\u91C7\u96C6\u7684\u6708\u7403\u7384\u6B66\u5CA9\u6837\u672C\uFF0C\u91CD\u7EA6110\u514B\u3002\u8868\u9762\u53EF\u89C1\u51B2\u51FB\u5751\u548C\u73BB\u7483\u8D28\u7194\u58F3\uFF0C\u662F\u7814\u7A76\u6708\u7403\u5F62\u6210\u4E0E\u6F14\u5316\u5386\u53F2\u7684\u73CD\u8D35\u5B9E\u7269\u3002"
    theme: 1
  - id: 5
    name: "\u84B8\u6C7D\u673A\u6A21\u578B"
    description: "\u74E6\u7279\u6539\u826F\u84B8\u6C7D\u673A\u76841:10\u7F29\u6BD4\u94DC\u5236\u6A21\u578B\u3002\u914D\u6709\u5206\u79BB\u51B7\u51DD\u5668\u3001\u79BB\u5FC3\u8C03\u901F\u5668\uFF0C\u5B8C\u6574\u5C55\u793A\u4E86\u84B8\u6C7D\u538B\u529B\u8F6C\u5316\u4E3A\u65CB\u8F6C\u52A8\u529B\u7684\u673A\u68B0\u539F\u7406\uFF0C\u6807\u5FD7\u7740\u5DE5\u4E1A\u9769\u547D\u7684\u5F00\u7AEF\u3002"
    theme: 2
  - id: 6
    name: "\u65E9\u671F\u8BA1\u7B97\u673A"
    description: "20\u4E16\u7EAA40\u5E74\u4EE3\u7535\u5B50\u7BA1\u8BA1\u7B97\u673A\u590D\u539F\u6A21\u578B\u3002\u4F7F\u7528\u7EA618000\u4E2A\u771F\u7A7A\u7BA1\uFF0C\u5360\u5730167\u5E73\u65B9\u7C73\uFF0C\u6BCF\u79D2\u53EF\u6267\u884C5000\u6B21\u52A0\u6CD5\u8FD0\u7B97\uFF0C\u662F\u73B0\u4EE3\u8BA1\u7B97\u673A\u53D1\u5C55\u53F2\u4E0A\u7684\u91CC\u7A0B\u7891\u3002"
    theme: 2
