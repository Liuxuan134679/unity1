using System.Collections.Generic;
using UnityEngine;

/// <summary>
/// 展示品配置 —— ScriptableObject，在 Project 窗口右键 Create > Museum > ExhibitConfig 创建
/// </summary>
[CreateAssetMenu(fileName = "ExhibitConfig", menuName = "Museum/ExhibitConfig")]
public class ExhibitConfig : ScriptableObject
{
    [Tooltip("所有展示品配置列表")]
    public List<ExhibitData> exhibits = new List<ExhibitData>();
}
