  exhibits:
  - id: 1
    name: "\u6F6E\u6C50\u5F52\u4F4D\u5BB9\u5668"
    fromTeacher: 0
    description: "\u8BE5\u5BB9\u5668\u6700\u521D\u88AB\u5F52\u7C7B\u4E3A[\u51DD\u6676\u6D41\u6001CRL01]\u56DE\u6536\u88C5\u7F6E\uFF0C\u5E95\u90E8\u523B\u6709\u201C\u7B2C\u4E5D\u6B21\u56DE\u6536\u6210\u529F\u201D\u6807\u8BB0\uFF0C\u5185\u90E8\u6B8B\u7559\u672A\u5B8C\u6210\u6F6E\u6C50\u7684\u6D41\u5411\u7EB9\u7406\uFF0C\u540E\u88AB\u4FEE\u6B63\u4E3A\u6F6E\u6C50\u5F52\u4F4D\u77EB\u6B63\u5DE5\u5177\u3002"
    theme: 0
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.72, g: 0.5, b: 0.28, a: 1}
  - id: 2
    name: "\u6DB2\u4F53\u5EFA\u7B51\u5C01\u5B58\u67F1"
    fromTeacher: 0
    description: "\u67F1\u4F53\u88AB\u8BB0\u5F55\u4E3A[\u51DD\u6676\u6D41\u6001CRL01]\u672A\u5B8C\u6210\u6DB2\u6001\u5EFA\u9020\u4F53\u7CFB\u7684\u51DD\u56FA\u4EA7\u7269\uFF0C\u7ED3\u6784\u957F\u671F\u7A33\u5B9A\uFF0C\u65E0\u584C\u89E3\u8FF9\u8C61"
    theme: 0
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.6, g: 0.85, b: 0.6, a: 1}
  - id: 3
    name: "\u51DD\u56FA\u822A\u9053\u6807\u5C3A"
    fromTeacher: 0
    description: "\u8BE5\u88C5\u7F6E\u88AB\u8BB0\u5F55\u4E3A[\u51DD\u6676\u6D41\u6001CRL01]\u6D77\u6D41\u822A\u7EBF\u6D4B\u91CF\u5DE5\u5177\uFF0C\u7528\u4E8E\u9501\u5B9A\u6D77\u6D41\u8DEF\u5F84\uFF0C\u5185\u90E8\u5D4C\u5165\u591A\u6BB5\u822A\u9053\u8F68\u8FF9\u6B8B\u7559\uFF0C\u9759\u6B62\u72B6\u6001\u4E0B\u4ECD\u4FDD\u7559\u65B9\u5411\u5EF6\u7EED\u6027\u3002"
    theme: 0
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.8, g: 0.65, b: 0.3, a: 1}
  - id: 4
    name: "\u6D77\u6D41\u8DEF\u5F84\u9501\u5B9A\u5668"
    fromTeacher: 0
    description: "[\u51DD\u6676\u6D41\u6001CRL01]\u6DB2\u6001\u63A7\u5236\u7CFB\u7EDF\u6B8B\u4F53\uFF0C\u7528\u4E8E\u7EA6\u675F\u6D77\u6D41\u8DEF\u5F84\uFF0C\u6D41\u5411\u5728\u9650\u5236\u72B6\u6001\u4E0B\u56FA\u5316\u4E3A\u91CD\u590D\u504F\u79FB\u7ED3\u6784\uFF0C\u8DEF\u5F84\u672A\u6062\u590D\u81EA\u7531\u72B6\u6001\u3002"
    theme: 0
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.65, g: 0.45, b: 0.35, a: 1}
  - id: 5
    name: "\u6F6E\u6C50\u80FD\u6E90\u51DD\u6838\u5668"
    fromTeacher: 0
    description: "\u6E90\u81EA\u6F6E\u6C50\u80FD\u91CF\u538B\u7F29\u56FA\u5316\u8FC7\u7A0B\uFF0C\u65CB\u8F6C\u80FD\u91CF\u6D41\u88AB\u5C01\u5B58\u4E8E\u7403\u72B6\u7ED3\u6784\u5E76\u5B8C\u6210\u7ED3\u6784\u5316\u56FA\u5B9A\uFF0C\u6574\u4F53\u7A33\u5B9A\uFF0C\u7591\u4F3C[\u51DD\u6676\u6D41\u6001CRL01]\u6838\u5FC3\u80FD\u6E90\u6765\u6E90\u3002"
    theme: 0
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.5, g: 0.35, b: 0.2, a: 1}
  - id: 6
    name: "\u70B9\u9635\u56DE\u5E94\u7FA4\u96C6"
    fromTeacher: 0
    description: "\u8BE5\u6676\u9635\u677F\u7528\u4E8E\u8BB0\u5F55\u591A\u70B9\u540C\u6B65\u56DE\u5E94\u884C\u4E3A\uFF0C\u88AB\u5F52\u5165[\u5171\u632F\u7FA4\u6838CRL02]\u65E9\u671F\u56DE\u5E94\u7CFB\u7EDF\u539F\u578B\u3002\u5176\u7A7A\u95F4\u6392\u5217\u65B9\u5F0F\u5DF2\u56FA\u5B9A\u4E3A\u6807\u51C6\u53C2\u8003\u6A21\u677F\u3002"
    theme: 1
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.55, g: 0.45, b: 0.3, a: 1}
  - id: 7
    name: "\u5931\u914D\u8BB0\u5F55\u4F53"
    fromTeacher: 0
    description: "\u5171\u9E23\u5931\u8D25\u540E\u5F62\u6210\u7684\u7ED3\u6784\u6B8B\u7559\u8BB0\u5F55\u5448\u591A\u91CD\u6676\u4F53\u9519\u4F4D\u53E0\u52A0\u72B6\u6001\uFF0C\u901A\u5E38\u5F52\u6863\u4E3A[\u5171\u632F\u7FA4\u6838CRL02]\u6587\u660E\u7684\u5F02\u5E38\u56DE\u54CD\u5206\u652F\u3002"
    theme: 1
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.3, g: 0.3, b: 0.4, a: 1}
  - id: 8
    name: "\u56DE\u54CD\u951A\u5B9A\u4E2D\u67A2"
    fromTeacher: 0
    description: "\u591A\u4EFD\u6863\u6848\u5C06\u5176\u6807\u8BB0\u4E3A[\u5171\u632F\u7FA4\u6838CRL02]\u5171\u9E23\u7F51\u7EDC\u7684\u7A33\u5B9A\u6838\u5FC3\uFF0C\u7528\u4E8E\u7EF4\u6301\u6574\u4F53\u56DE\u54CD\u7ED3\u6784\u7684\u6301\u7EED\u6027\uFF0C\u4E0D\u540C\u7248\u672C\u8BB0\u5F55\u9AD8\u5EA6\u4E00\u81F4\u3002"
    theme: 1
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.9, g: 0.5, b: 0.55, a: 1}
  - id: 9
    name: "\u53CC\u6676\u6838\u5171\u9E23\u4F53"
    fromTeacher: 0
    description: "\u8BE5\u9057\u4EA7\u7528\u4E8E\u627F\u8F7D\u53CC\u6E90\u5171\u9E23\u5173\u7CFB\u7684\u57FA\u7840\u9A8C\u8BC1\uFF0C\u5BF9\u7406\u89E3[\u5171\u632F\u7FA4\u6838RCL02]\u6587\u660E\u5171\u9E23\u7ED3\u6784\u5177\u6709\u5173\u952E\u53C2\u8003\u4EF7\u503C\uFF0C\u4F46\u90E8\u5206\u673A\u5236\u4ECD\u65E0\u6CD5\u5B8C\u5168\u590D\u539F\u3002"
    theme: 1
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.9, g: 0.75, b: 0.25, a: 1}
  - id: 10
    name: "\u87BA\u65CB\u56DE\u58F0\u901A\u9053"
    fromTeacher: 0
    description: "\u88AB\u5F52\u5165[\u5171\u632F\u7FA4\u6838CRL02]\u4F20\u64AD\u578B\u5171\u9E23\u8DEF\u5F84\u7814\u7A76\u8BB0\u5F55\uFF0C\u5728\u591A\u4EFD\u6D4B\u7ED8\u6863\u6848\u4E2D\u53CD\u590D\u51FA\u73B0\uFF0C\u7528\u4E8E\u9A8C\u8BC1\u56DE\u58F0\u4F20\u64AD\u8FC7\u7A0B\u4E2D\u7684\u8DEF\u5F84\u5EF6\u7EED\u4E0E\u53CD\u5C04\u673A\u5236\u3002\u3002"
    theme: 1
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.85, g: 0.65, b: 0.2, a: 1}
  - id: 11
    name: "\u7EC8\u7AEF\u6B8B\u5B58\u5BFC\u822A\u7891"
    fromTeacher: 0
    description: "\"[\u5411\u8FF9\u805A\u7C92TPL03]\u6700\u65E9\u671F\u65B9\u4F4D\u6807\u8BB0\u9057\u7269\uFF0C\u7528\u4E8E\u786E\u7ACB\u7A7A\u95F4\u53EF\u62B5\u8FBE\u6027\u3002\u591A\u6B21\u8003\u53E4\u590D\u6838\u663E\u793A\uFF0C\u5176\u6B8B\u7559\u6307\u5411\u4ECD\u53EF\u4F5C\u4E3A\u6709\u6548\u65B9\u5411\u4F9D\u636E\u3002\n\""
    theme: 2
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.4, g: 0.55, b: 0.75, a: 1}
  - id: 12
    name: "\u65F6\u7A7A\u6D4B\u7ED8\u677F"
    fromTeacher: 0
    description: "\u8BB0\u5F55\u8DE8\u65F6\u7A7A\u8DEF\u5F84\u7684\u65B9\u4F4D\u9057\u4EA7\uFF0C\u7528\u4E8E\u6784\u5EFA[\u5411\u8FF9\u805A\u7C92TPL03]\u591A\u5C42\u5750\u6807\u53C2\u8003\u4F53\u7CFB\uFF0C\u5176\u6D4B\u7ED8\u7ED3\u679C\u4ECD\u53EF\u7528\u4E8E\u4FEE\u6B63\u5B87\u5B99\u5C3A\u5EA6\u5B9A\u4F4D\u504F\u5DEE\u3002"
    theme: 2
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.5, g: 0.4, b: 0.3, a: 1}
  - id: 13
    name: "\u65B9\u5411\u6821\u51C6\u6B8B\u5854"
    fromTeacher: 0
    description: "\u7EF4\u6301\u5B87\u5B99\u65B9\u4F4D\u7EDF\u4E00\u7684\u6838\u5FC3\u9057\u4EA7\u4E4B\u4E00\uFF0C\u7528\u4E8E\u4FEE\u6B63\u7A7A\u95F4\u65B9\u5411\u504F\u79FB\uFF0C\u5176\u6B8B\u5B58\u6821\u51C6\u673A\u5236\u6301\u7EED\u62C9\u6B63\u5468\u8FB9\u7A7A\u95F4\u6307\u5411\uFF0C\u4F7F[\u5411\u8FF9\u805A\u7C92TPL03]\u9644\u8FD1\u5750\u6807\u9010\u6B65\u8D8B\u5411\u540C\u4E00\u65B9\u5411\u8F74\u3002"
    theme: 2
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.3, g: 0.25, b: 0.2, a: 1}
  - id: 14
    name: "\u5750\u6807\u6F02\u79FB\u6807\u8BB0\u5668"
    fromTeacher: 0
    description: "\u7528\u4E8E\u52A8\u6001\u65B9\u4F4D\u6807\u5B9A\u7684\u9057\u4EA7\u88C5\u7F6E\uFF0C\u5728\u4E0D\u7A33\u5B9A\u7A7A\u95F4\u4E2D\u7EF4\u6301\u53C2\u8003\u5750\u6807\u3002[\u5411\u8FF9\u805A\u7C92TPL03]\u5750\u6807\u6F02\u79FB\u672C\u8EAB\u4EA6\u88AB\u7EB3\u5165\u5B9A\u4F4D\u7CFB\u7EDF\u7ED3\u6784\u3002"
    theme: 2
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.2, g: 0.2, b: 0.22, a: 1}
  - id: 15
    name: "\u65AD\u4EE3\u8DEF\u5F84\u5B58\u7EED\u76D2"
    fromTeacher: 0
    description: "\u7528\u4E8E\u4FDD\u5B58[\u5411\u8FF9\u805A\u7C92TPL03]\u6587\u660E\u53EF\u62B5\u8FBE\u8DEF\u5F84\u4E0E\u65B9\u5411\u6B8B\u7247\u7684\u5C01\u5B58\u9057\u4EA7\u3002\u5C3D\u7BA1\u7ED3\u6784\u53D7\u635F\uFF0C\u5176\u5185\u90E8\u8DEF\u5F84\u4ECD\u88AB\u89C6\u4E3A\u201C\u53EF\u62B5\u8FBE\u6027\u4ECD\u6210\u7ACB\u201D\u7684\u7A7A\u95F4\u8BC1\u636E\u3002"
    theme: 2
    icon: {fileID: 21300000, guid: 872a52e46de3fa14e8c1a3836bd85fe2, type: 3}
    color: {r: 0.45, g: 0.5, b: 0.55, a: 1}
  - id: 16
    name: "\u7834\u635F\u5DE5\u4F5C\u8BC1"
    fromTeacher: 1
    description: "\u8FDB\u5165\u7B2C\u4E00\u4E2A[\u51DD\u6676\u6D41\u6001CRL01]\u9057\u5740\u65F6\u4ECD\u5728\u4F7F\u7528\u8FD9\u5F20\u8BC1\u4EF6\u3002\u5176\u8C61\u5F81\u56FE\u6848\u5728\u5165\u53E3\u5904\u53CD\u590D\u51FA\u73B0\uFF0C\u4E0E\u6211[\u6D82\u9ED1\u6807\u8BB0]\u7684\u8EAB\u4EFD\u8BB0\u5F55\u9AD8\u5EA6\u76F8\u4F3C\uFF0C\u6211\u5F00\u59CB\u6000\u7591\u5206\u7C7B\u7CFB\u7EDF\u672C\u8EAB\u662F\u5426\u6210\u7ACB\u3002"
    theme: 0
    icon: {fileID: 21300000, guid: ea96ca991d5103d458ac7c26dfd09c49, type: 3}
    color: {r: 0.45, g: 0.5, b: 0.55, a: 1}
  - id: 17
    name: "\u6807\u6CE8\u8FC7\u7684\u661F\u56FE"
    fromTeacher: 1
    description: "\u6211\u5C06\u51DD\u6676\u6D41\u6001\u4E0E\u5171\u632F\u7FA4\u6838\u7684\u89C2\u6D4B\u70B9\u6807\u8BB0\u5728\u540C\u4E00\u5F20\u661F\u56FE\u4E0A\u3002\u540C\u4E00\u7EC4\u56FE\u6848\u5728\u4E0D\u540C\u533A\u57DF\u91CD\u590D\u51FA\u73B0\uFF0C\u5374\u88AB\u5212\u5165\u4E92\u76F8\u51B2\u7A81\u7684\u6587\u660E\u5206\u7C7B\u3002\u6211\u8D8A\u662F\u7ED8\u5236\uFF0C\u8D8A\u89C9\u5F97\u8FD9\u4E9B\u6807\u8BB0\u5E76\u975E\u7B80\u5355\u7684\u5206\u7C7B\u7ED3\u679C\u3002"
    theme: 0
    icon: {fileID: 21300000, guid: 8c3ec8df46455e84f8131357c5049683, type: 3}
    color: {r: 0.45, g: 0.5, b: 0.55, a: 1}
  - id: 18
    name: "\u5B9A\u4F4D\u4FE1\u6807"
    fromTeacher: 1
    description: "\"\u6211\u56DE\u5230[\u5411\u8FF9\u805A\u7C92TPL03]\u9057\u5740\uFF0C\u91CD\u65B0\u542F\u7528\u5B9A\u4F4D\u4FE1\u6807\u4E0E\u65B9\u5411\u89E3\u7801\u5668\u3002\u4FE1\u6807\u4ECD\u6307\u5411\u540C\u4E00\u6761\u5F52\u6863\u8D77\u59CB\u8F74\uFF0C\u8FD9\u6761\u8F74\u5728\u65E7\u8BB0\u5F55\u4E2D\u88AB\u6807\u8BB0\u4E3A\u201C\u8FD4\u56DE\u8DEF\u5F84\u201D\u3002\n\u7CFB\u7EDF\u91CD\u65B0\u8BC6\u522B\u4E86\u6211\u7684\u5F52\u6863\u8EAB\u4EFD\u6743\u9650\u2014\u2014\u4ECD\u5C5E\u4E8E[\u5411\u8FF9\u805A\u7C92TPL03]\u9057\u6C11\u5E8F\u5217\u3002\n\n\u6211\u4E00\u76F4\u5C1D\u8BD5\u8BA9\u8FD9\u4E9B\u65AD\u88C2\u7684\u8BB0\u5F55\u91CD\u65B0\u786E\u5B9A\u4E3A\u201C\u53EF\u88AB\u951A\u5B9A\u7684\u6587\u660E\u201D\uFF0C\u4F46\u73B0\u5728\u770B\u6765\uFF0C\u6211\u5FC5\u987B\u5728\u5B83\u4EEC\u5F7B\u5E95\u5931\u53BB\u53EF\u5BF9\u9F50\u6027\u4E4B\u524D\uFF0C\u5B8C\u6210\u6700\u540E\u4E00\u6B21\u6821\u51C6\u4E0E\u62B5\u8FBE\u3002\""
    theme: 1
    icon: {fileID: 21300000, guid: 58d1b37d42736ab4ea9d6834e1a3afa4, type: 3}
    color: {r: 0.45, g: 0.5, b: 0.55, a: 1}
  - id: 19
    name: "\u624B\u5199\u8C03\u67E5\u7B14\u8BB0"
    fromTeacher: 1
    description: "\u6676\u6838\u7ED3\u6784\u4E0E\u6D41\u4F53\u7ED3\u6784\u4E4B\u95F4\u5B58\u5728\u65E0\u6CD5\u89E3\u91CA\u7684\u5BF9\u5E94\u5173\u7CFB\u3002\u6211\u8BD5\u56FE\u62C6\u5206\u7406\u89E3\uFF0C\u4F46\u6BCF\u6B21\u90FD\u4F1A\u56DE\u5230\u540C\u4E00\u7ED3\u8BBA\u9644\u8FD1\uFF0C\u53C8\u88AB\u91CD\u65B0\u63A8\u5F00\u3002"
    theme: 1
    icon: {fileID: 21300000, guid: a2f46d985af43c349a3d969125cb616f, type: 3}
    color: {r: 0.45, g: 0.5, b: 0.55, a: 1}
  - id: 20
    name: "\u626B\u63CF\u8BB0\u5F55\u78C1\u5E26"
    fromTeacher: 1
    description: "[\u5171\u632F\u7FA4\u6838RCL02]\u4FE1\u53F7\u5728\u6D41\u6001\u9057\u5740\u4E2D\u4ECD\u53EF\u6355\u6349\u5230\u5FAE\u5F31\u6B8B\u7559\uFF0C\u4F46\u8868\u73B0\u5F62\u5F0F\u53D1\u751F\u53D8\u5316\u3002\u8BB0\u5F55\u7ED3\u679C\u4E0D\u7A33\u5B9A\uFF0C\u6BCF\u6B21\u5448\u73B0\u5F62\u6001\u4E0D\u540C\u3002\u6211\u65E0\u6CD5\u5224\u65AD\u662F\u8BBE\u5907\u8BEF\u5DEE\uFF0C\u8FD8\u662F\u8FD9\u79CD\u201C\u5DEE\u5F02\u672C\u8EAB\u5373\u4E3A\u7A33\u5B9A\u72B6\u6001\u201D\u3002"
    theme: 2
